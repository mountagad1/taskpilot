# ─── TaskPilot Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in all values before running the app.
# Never commit .env.local or any file with real secrets to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key  # NEVER expose this to the browser

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# From: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...your-stripe-secret-key   # Use sk_live_ in production
STRIPE_WEBHOOK_SECRET=whsec_...your-webhook-signing-secret  # From Stripe CLI or dashboard

# Stripe Price IDs (from Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY=price_...pro_monthly_price_id
STRIPE_PRICE_PRO_ANNUAL=price_...pro_annual_price_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...enterprise_monthly_price_id

# Public key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...your-publishable-key

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# From: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-upstash-token

# ─── PostHog Analytics (optional) ────────────────────────────────────────────
# From: https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://taskpilot.cc          # Set to http://localhost:3000 in dev
NEXT_PUBLIC_APP_NAME=TaskPilot

# ─── Extension Config ─────────────────────────────────────────────────────────
# The Chrome extension ID (found in chrome://extensions after loading the extension)
NEXT_PUBLIC_EXTENSION_ID=your-extension-id-here

# ─── Email (Resend) — Optional ────────────────────────────────────────────────
# From: https://resend.com
RESEND_API_KEY=re_...your-resend-key
EMAIL_FROM=hello@taskpilot.cc

# ─── Trigger.dev Jobs — Optional ─────────────────────────────────────────────
# From: https://trigger.dev
TRIGGER_API_KEY=tr_...your-trigger-key
TRIGGER_API_URL=https://api.trigger.dev

# ─── Rate Limiting Config ─────────────────────────────────────────────────────
# Overrides (optional — defaults are in security.ts)
RATE_LIMIT_SMART_PASTE=30    # requests per minute
RATE_LIMIT_PROCESS=60
RATE_LIMIT_AUTH=10
